# ─────────────────────────────────────────────────────────────────
#  SmartFeed AI – Environment Variables Template  (v2)
#  Copy this file to .env and fill in all values below
# ─────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── JWT ──────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ── Firebase Admin SDK ────────────────────────────────────────────
# Option A: Path to downloaded service account JSON
FIREBASE_SERVICE_ACCOUNT_PATH=./config/serviceAccountKey.json

# Option B: Individual env vars (use this for Railway/Render)
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"

# Firebase Web API Key (for login password verification)
FIREBASE_WEB_API_KEY=your_firebase_web_api_key

# ── Razorpay ──────────────────────────────────────────────────────
# Get these from https://dashboard.razorpay.com → Settings → API Keys
# Use TEST mode keys during development
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Amount in paise (100 paise = ₹1)
RAZORPAY_AMOUNT=100
RAZORPAY_CURRENCY=INR

# ── Email (Nodemailer / Gmail SMTP) ──────────────────────────────
# Use a Gmail account — enable "App Passwords" in Google Account settings
# (2-Factor Auth must be ON, then generate an App Password for "Mail")
EMAIL_USER=your_gmail@gmail.com
EMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# Admin email — receives approval requests
ADMIN_EMAIL=adarshbhandage20@gmail.com

# ── App URLs ──────────────────────────────────────────────────────
# Frontend origin (for CORS)
FRONTEND_URL=http://localhost:3000

# Backend base URL — used to build approve/reject links in emails
# Change to your deployed URL in production
BACKEND_URL=http://localhost:5000

# ── Approval Token Secret ─────────────────────────────────────────
# Used to sign secure approve/reject links — keep this private
APPROVAL_SECRET=your_approval_link_secret_change_this
